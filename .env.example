GPSTRACK_APP_NAME=GpsTrack API
GPSTRACK_APP_VERSION=0.1.0
GPSTRACK_API_V1_PREFIX=/api/v1
GPSTRACK_API_PORT=8000
GPSTRACK_DATABASE_URL=postgresql+psycopg://gpstrack:gpstrack@db:5432/gpstrack
GPSTRACK_DB_PORT=5432
GPSTRACK_RETENTION_DAYS=7
GPSTRACK_AUTH_MODE=open
GPSTRACK_OPEN_AUTH_FAMILY_SLUG=dev-family
GPSTRACK_OPEN_AUTH_PARENT_SUBJECT=dev-parent
GPSTRACK_DEFAULT_FAMILY_NAME=GpsTrack Family
GPSTRACK_OIDC_ISSUER_URL=
GPSTRACK_OIDC_CLIENT_ID=
GPSTRACK_OIDC_AUDIENCE=
GPSTRACK_OIDC_JWKS_URL=
GPSTRACK_ENABLE_HOME_ASSISTANT_INGESTION=false
GPSTRACK_HOME_ASSISTANT_BOOTSTRAP_MEMBERS=[]
GPSTRACK_HOME_ASSISTANT_WS_URL=ws://homeassistant.local:8123/api/websocket
GPSTRACK_HOME_ASSISTANT_ACCESS_TOKEN=replace-me
