PRESENCE_TIMELINE_APP_NAME=Presence Timeline API
PRESENCE_TIMELINE_APP_VERSION=0.1.0
PRESENCE_TIMELINE_API_V1_PREFIX=/api/v1
PRESENCE_TIMELINE_API_PORT=8000
PRESENCE_TIMELINE_DATABASE_URL=postgresql+psycopg://presence_timeline:presence_timeline@db:5432/presence_timeline
PRESENCE_TIMELINE_DB_PORT=5432
PRESENCE_TIMELINE_RETENTION_DAYS=7
PRESENCE_TIMELINE_AUTH_MODE=open
PRESENCE_TIMELINE_OPEN_AUTH_FAMILY_SLUG=dev-family
PRESENCE_TIMELINE_OPEN_AUTH_PARENT_SUBJECT=dev-parent
PRESENCE_TIMELINE_DEFAULT_FAMILY_NAME=Presence Timeline Family
PRESENCE_TIMELINE_OIDC_ISSUER_URL=
PRESENCE_TIMELINE_OIDC_CLIENT_ID=
PRESENCE_TIMELINE_OIDC_AUDIENCE=
PRESENCE_TIMELINE_OIDC_JWKS_URL=
PRESENCE_TIMELINE_ENABLE_HOME_ASSISTANT_INGESTION=false
PRESENCE_TIMELINE_HOME_ASSISTANT_BOOTSTRAP_MEMBERS=[]
PRESENCE_TIMELINE_HOME_ASSISTANT_WS_URL=ws://homeassistant.local:8123/api/websocket
PRESENCE_TIMELINE_HOME_ASSISTANT_ACCESS_TOKEN=replace-me
PRESENCE_TIMELINE_ENABLE_REVERSE_GEOCODING=true
PRESENCE_TIMELINE_REVERSE_GEOCODE_URL=https://nominatim.openstreetmap.org/reverse
PRESENCE_TIMELINE_REVERSE_GEOCODE_USER_AGENT=presence-timeline/0.1.0
PRESENCE_TIMELINE_REVERSE_GEOCODE_TIMEOUT_SECONDS=5.0
PRESENCE_TIMELINE_REVERSE_GEOCODE_CACHE_PRECISION=4
PRESENCE_TIMELINE_REVERSE_GEOCODE_RETRY_MINUTES=15
PRESENCE_TIMELINE_REVERSE_GEOCODE_BATCH_SIZE=10
PRESENCE_TIMELINE_REVERSE_GEOCODE_BACKFILL_LIMIT=500
PRESENCE_TIMELINE_REVERSE_GEOCODE_WORKER_INTERVAL_SECONDS=60
